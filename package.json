{
  "name": "sul-local",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "cd apps && python3 -m uvicorn api.main:app --reload --port 8000",
    "dev:web": "pnpm --filter web dev",
    "lint": "turbo lint",
    "lint:py": "ruff check apps/api/ && ruff format --check apps/api/",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:py": "ruff format apps/api/",
    "check": "pnpm run lint && pnpm run lint:py",
    "test": "echo \"No tests defined yet\"",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
